rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Safety default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerifiedUser() {
      return isSignedIn();
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Reference to incoming data
    function incoming() {
      return request.resource.data;
    }

    // Reference to existing data
    function existing() {
      return resource.data;
    }

    function getUserData(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data;
    }

    function isOwner(userId) {
      return isVerifiedUser() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isVerifiedUser() && (
        request.auth.token.email == 'stinger911@gmail.com' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'user') == 'admin')
      );
    }

    // Allow connection test
    match /system_configs/{configId} {
      allow read: if true;
    }

    // Users Collection
    match /users/{userId} {
      function isValidUser(data) {
        return data.get('uid', '') is string && data.get('uid', '').size() <= 128
          && data.get('email', '') is string && data.get('email', '').size() <= 256
          && data.get('displayName', '') is string && data.get('displayName', '').size() <= 256
          && data.get('role', 'user') is string && (data.get('role', 'user') == 'user' || data.get('role', 'user') == 'admin')
          && data.get('subscriptionStatus', 'free') is string && (data.get('subscriptionStatus', 'free') == 'free' || data.get('subscriptionStatus', 'free') == 'premium');
      }

      allow get: if isOwner(userId) || (isVerifiedUser() && !isOwner(userId) && isAdmin());
      allow list: if isAdmin();
      
      allow create: if isOwner(userId) && isValidUser(incoming()) 
        && incoming().get('uid', '') == request.auth.uid 
        && (incoming().get('role', 'user') == 'user' || (request.auth.token.email == 'stinger911@gmail.com' && incoming().get('role', 'user') == 'admin')) 
        && incoming().get('createdAt', request.time) == request.time;
      
      allow update: if isOwner(userId) && isValidUser(incoming())
        && incoming().get('uid', '') == existing().get('uid', '')
        && incoming().get('createdAt', request.time) == existing().get('createdAt', request.time)
        && (incoming().get('role', 'user') == existing().get('role', 'user') || isAdmin());
      
      allow delete: if isAdmin();
    }

    // Books Collection
    match /books/{bookId} {
      allow get: if isVerifiedUser() && (
        resource.data.userId == request.auth.uid || 
        (resource.data.get('isPublic', false) == true && resource.data.get('moderationStatus', 'pending') == 'approved') || 
        isAdmin()
      );
      allow list: if isVerifiedUser() && (
        resource.data.userId == request.auth.uid || 
        (resource.data.get('isPublic', false) == true && resource.data.get('moderationStatus', 'pending') == 'approved') || 
        isAdmin()
      );

      allow create: if isVerifiedUser() && 
        request.resource.data.userId == request.auth.uid;

      allow update: if isVerifiedUser() && (
        resource.data.userId == request.auth.uid || 
        isAdmin()
      );

      allow delete: if isVerifiedUser() && (
        resource.data.userId == request.auth.uid || 
        isAdmin()
      );
    }
  }
}
